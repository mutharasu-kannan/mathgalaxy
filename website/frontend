<script>
// ===== STATE =====
let currentUser = null;
let currentKey = null;
let graphChart = null;
let expenseChartInst = null;
let budChartInst = null;
let licChartInst = null;
let todoChartInst = null;
let habitChartInst = null;

// ===== PARTICLES =====
(function(){
  const c=document.getElementById('particles');
  const ctx=c.getContext('2d');
  let W,H,pts=[];
  function resize(){W=c.width=window.innerWidth;H=c.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);
  for(let i=0;i<80;i++){
    pts.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.5+.5,
      vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,
      op:Math.random()*.6+.1});
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(245,230,66,${p.op})`;ctx.fill();
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W)p.vx*=-1;
      if(p.y<0||p.y>H)p.vy*=-1;
    });
    // draw connections
    for(let i=0;i<pts.length;i++){
      for(let j=i+1;j<pts.length;j++){
        const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
        if(d<120){
          ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);
          ctx.strokeStyle=`rgba(245,230,66,${.12*(1-d/120)})`;ctx.lineWidth=.5;ctx.stroke();
        }
      }
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

// ===== STORAGE =====
function getDB(){return JSON.parse(localStorage.getItem('mathgalaxy_db')||'{}');}
function saveDB(db){localStorage.setItem('mathgalaxy_db',JSON.stringify(db));}
function getUserData(){const db=getDB();return db[currentKey]||{history:[],expenses:[],todos:[],habits:[],studProgress:[],gpaSubjects:[],cgpaSems:[],cgpaSubjects:[]};}
function saveUserData(data){const db=getDB();db[currentKey]=data;saveDB(db);}
function addHistory(type,content){
  if(!currentKey)return;
  const d=getUserData();
  d.history=d.history||[];
  d.history.unshift({type,content,time:new Date().toLocaleString()});
  if(d.history.length>100)d.history.pop();
  saveUserData(d);
}

// ===== LOGIN =====
function doLogin(){
  const name=document.getElementById('loginName').value.trim();
  const uid=document.getElementById('loginId').value.trim();
  const age=document.getElementById('loginAge').value.trim();
  const inst=document.getElementById('loginInst').value.trim();
  if(!name||!uid){alert('Please enter Name and ID');return;}
  currentKey=`${name.toLowerCase()}_${uid}`;
  const db=getDB();
  if(!db[currentKey]){db[currentKey]={name,uid,age,inst,history:[],expenses:[],todos:[],habits:[],studProgress:[],cgpaSems:[],gpaSubjects:[]};saveDB(db);}
  currentUser={name,uid,age,inst};
  showPage('loadingPage');
  startLoading();
}

const QUOTES=[
  'Mathematics is the language of the universe.',
  'Every problem has a solution — find it.',
  'Without mathematics, there\'s nothing you can do.',
  'Mathematics is not about numbers, but about understanding.',
  'The only way to learn mathematics is to do mathematics.',
  'Mathematics is the queen of all sciences.',
  'A problem is a chance for you to do your best.',
  'Imagination is more important than knowledge.',
];
let qIdx=0;
function startLoading(){
  let prog=0;
  const bar=document.getElementById('loadingBar');
  const quote=document.getElementById('loadingQuote');
  quote.textContent=QUOTES[qIdx++%QUOTES.length];
  const intv=setInterval(()=>{
    prog+=Math.random()*15+5;
    if(prog>100)prog=100;
    bar.style.width=prog+'%';
    if(prog<100){quote.textContent=QUOTES[qIdx++%QUOTES.length];}
    else{clearInterval(intv);setTimeout(()=>openDash(),500);}
  },700);
}
function openDash(){
  document.getElementById('dashWelcome').textContent=`Welcome to Math Galaxy, ${currentUser.name} ✦`;
  document.getElementById('dashSub').textContent=`Thank you for using Math Galaxy.`;
  document.getElementById('userBadge').textContent=`✦ ${currentUser.name}`;
  showPage('dashPage');
