  't':{transform:'1/s²',cond:'s > 0'},
  't2':{transform:'2/s³',cond:'s > 0'},
  'tn':{transform:'n!/s^(n+1)',cond:'s > 0'},
  'eat':{transform:'1/(s-a)',cond:'s > a'},
  'sinat':{transform:'a/(s²+a²)',cond:'s > 0'},
  'cosat':{transform:'s/(s²+a²)',cond:'s > 0'},
  'teat':{transform:'1/(s-a)²',cond:'s > a'},
};
function solveLaplace(){
