<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Math Galaxy — Futuristic Calculator Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root {
  --black: #050508;
  --deep: #0a0a12;
  --card: rgba(20,20,35,0.85);
  --yellow: #f5e642;
  --yellow2: #ffe94d;
  --yellow-dim: rgba(245,230,66,0.12);
  --yellow-glow: rgba(245,230,66,0.35);
  --glass: rgba(255,255,255,0.04);
  --glass-border: rgba(245,230,66,0.18);
  --text: #f0f0f8;
  --muted: #8888aa;
  --radius: 24px;
  --radius-sm: 14px;
  --font-head: 'Poppins', sans-serif;
  --font-body: 'Inter', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;min-height:100%;background:var(--black);color:var(--text);font-family:var(--font-body);overflow-x:hidden;}
/* ===== PARTICLES ===== */
#particles{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}
/* ===== PAGES ===== */
.page{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10;overflow-y:auto;display:none;flex-direction:column;background:var(--black);}
.page.active{display:flex;}
/* ===== LOGIN ===== */
#loginPage{align-items:center;justify-content:center;}
.login-box{background:rgba(12,12,22,0.95);border:1px solid var(--glass-border);border-radius:32px;padding:52px 44px;max-width:460px;width:92%;box-shadow:0 0 80px rgba(245,230,66,0.1),0 20px 60px rgba(0,0,0,0.7);backdrop-filter:blur(20px);position:relative;z-index:2;}
.login-logo{text-align:center;margin-bottom:36px;}
.login-logo .star{font-size:52px;display:block;animation:floatY 3s ease-in-out infinite;}
.login-logo h1{font-family:var(--font-head);font-size:2rem;font-weight:900;color:var(--yellow);letter-spacing:2px;text-shadow:0 0 30px var(--yellow-glow);}
.login-logo p{color:var(--muted);font-size:.85rem;margin-top:4px;}
.form-group{margin-bottom:20px;}
.form-group label{display:block;font-size:.8rem;font-weight:600;color:var(--yellow);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;}
.form-group input,.form-group select{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(245,230,66,0.2);border-radius:12px;padding:13px 18px;color:var(--text);font-family:var(--font-body);font-size:.95rem;outline:none;transition:all .3s;}
.form-group input:focus,.form-group select:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(245,230,66,0.12);}
.form-group select option{background:#0a0a12;}
.btn-login{width:100%;padding:15px;background:var(--yellow);color:#000;border:none;border-radius:14px;font-family:var(--font-head);font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:1px;transition:all .3s;margin-top:8px;}
.btn-login:hover{background:var(--yellow2);box-shadow:0 0 30px var(--yellow-glow);transform:translateY(-2px);}
/* ===== LOADING ===== */
#loadingPage{align-items:center;justify-content:center;flex-direction:column;gap:40px;}
.loading-orb{width:120px;height:120px;border-radius:50%;border:3px solid transparent;border-top:3px solid var(--yellow);border-right:3px solid var(--yellow);animation:spin 1.2s linear infinite;position:relative;box-shadow:0 0 40px var(--yellow-glow);}
.loading-orb::after{content:'✦';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:2.5rem;color:var(--yellow);animation:pulse 1.2s ease-in-out infinite;}
.loading-quote{font-family:var(--font-head);font-size:1.3rem;font-weight:600;color:var(--yellow);text-align:center;max-width:500px;padding:0 20px;opacity:0;animation:fadeQuote 2s ease-in-out infinite;}
.loading-bar-wrap{width:300px;height:4px;background:rgba(255,255,255,0.1);border-radius:4px;overflow:hidden;}
.loading-bar{height:100%;background:linear-gradient(90deg,var(--yellow),var(--yellow2));border-radius:4px;width:0;transition:width .3s;}
/* ===== DASHBOARD ===== */
#dashPage{background:var(--black);}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:20px 36px;background:rgba(10,10,18,0.9);border-bottom:1px solid var(--glass-border);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100;}
.topbar-logo{font-family:var(--font-head);font-weight:900;font-size:1.3rem;color:var(--yellow);letter-spacing:2px;}
.topbar-logo span{color:var(--text);}
.topbar-nav{display:flex;gap:8px;}
.nav-btn{background:transparent;border:1px solid rgba(255,255,255,0.1);color:var(--muted);padding:8px 18px;border-radius:30px;font-size:.82rem;font-family:var(--font-body);cursor:pointer;transition:all .3s;}
.nav-btn:hover,.nav-btn.active{background:var(--yellow-dim);border-color:var(--yellow);color:var(--yellow);}
.user-badge{background:var(--yellow-dim);border:1px solid var(--glass-border);border-radius:30px;padding:8px 18px;font-size:.82rem;color:var(--yellow);}
.dash-hero{padding:60px 36px 30px;text-align:center;}
.dash-hero h2{font-family:var(--font-head);font-size:2.6rem;font-weight:900;color:var(--yellow);text-shadow:0 0 40px var(--yellow-glow);line-height:1.2;}
.dash-hero p{color:var(--muted);margin-top:10px;font-size:1rem;}
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;padding:20px 36px 80px;max-width:1200px;margin:0 auto;width:100%;}
.main-card{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius);padding:44px 32px;cursor:pointer;transition:all .4s cubic-bezier(.23,1,.32,1);position:relative;overflow:hidden;backdrop-filter:blur(16px);}
.main-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--yellow),transparent);opacity:0;transition:opacity .4s;}
.main-card:hover{transform:translateY(-12px) scale(1.02);box-shadow:0 30px 80px rgba(245,230,66,0.15),0 0 0 1px var(--yellow);background:rgba(20,20,35,0.98);}
.main-card:hover::before{opacity:1;}
.card-icon{font-size:3.5rem;margin-bottom:20px;display:block;animation:floatY 3s ease-in-out infinite;}
.main-card:nth-child(2) .card-icon{animation-delay:.5s;}
.main-card:nth-child(3) .card-icon{animation-delay:1s;}
.card-title{font-family:var(--font-head);font-size:1.4rem;font-weight:700;color:var(--yellow);margin-bottom:10px;}
.card-desc{color:var(--muted);font-size:.88rem;line-height:1.6;}
.card-arrow{position:absolute;bottom:24px;right:28px;color:var(--yellow);font-size:1.5rem;opacity:.5;transition:all .3s;}
.main-card:hover .card-arrow{opacity:1;transform:translateX(5px);}
/* ===== INNER PAGES ===== */
#calcPage,#lifePage,#studPage,#histPage,#aboutPage,#teamPage{background:var(--black);}
.inner-header{display:flex;align-items:center;gap:16px;padding:24px 36px;background:rgba(10,10,18,0.9);border-bottom:1px solid var(--glass-border);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100;}
.back-btn{background:var(--yellow-dim);border:1px solid var(--glass-border);color:var(--yellow);width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;transition:all .3s;flex-shrink:0;}
.back-btn:hover{background:var(--yellow);color:#000;}
.inner-header h2{font-family:var(--font-head);font-size:1.4rem;font-weight:700;color:var(--yellow);}
.inner-content{padding:32px 36px;max-width:1200px;margin:0 auto;width:100%;}
/* ===== TOOL GRID ===== */
.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:18px;margin-bottom:40px;}
.tool-card{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:28px 22px;cursor:pointer;transition:all .3s;text-align:center;backdrop-filter:blur(12px);}
.tool-card:hover{border-color:var(--yellow);background:rgba(245,230,66,0.06);transform:translateY(-4px);box-shadow:0 12px 40px rgba(245,230,66,0.1);}
.tool-card .t-icon{font-size:2.2rem;margin-bottom:12px;}
.tool-card .t-name{font-family:var(--font-head);font-size:.95rem;font-weight:600;color:var(--text);}
/* ===== CALCULATOR PANELS ===== */
.calc-panel{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius);padding:36px;backdrop-filter:blur(16px);margin-bottom:24px;display:none;}
.calc-panel.active{display:block;animation:fadeIn .4s ease;}
.calc-panel h3{font-family:var(--font-head);font-size:1.2rem;font-weight:700;color:var(--yellow);margin-bottom:24px;}
.input-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:18px;}
.inp-group label{display:block;font-size:.78rem;font-weight:600;color:var(--yellow);letter-spacing:.8px;text-transform:uppercase;margin-bottom:6px;}
.inp-group input,.inp-group select,.inp-group textarea{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(245,230,66,0.18);border-radius:10px;padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:.92rem;outline:none;transition:all .3s;}
.inp-group input:focus,.inp-group select:focus,.inp-group textarea:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(245,230,66,0.1);}
.inp-group select option{background:#0a0a12;}
.inp-group textarea{min-height:80px;resize:vertical;}
.btn-calc{background:var(--yellow);color:#000;border:none;border-radius:10px;padding:12px 28px;font-family:var(--font-head);font-size:.9rem;font-weight:700;cursor:pointer;transition:all .3s;margin-top:8px;}
.btn-calc:hover{background:var(--yellow2);box-shadow:0 0 20px var(--yellow-glow);transform:translateY(-2px);}
.btn-sec{background:transparent;color:var(--yellow);border:1px solid var(--yellow);border-radius:10px;padding:12px 28px;font-family:var(--font-head);font-size:.9rem;font-weight:700;cursor:pointer;transition:all .3s;margin-top:8px;margin-left:10px;}
.btn-sec:hover{background:var(--yellow-dim);}
.result-box{background:rgba(245,230,66,0.07);border:1px solid rgba(245,230,66,0.25);border-radius:12px;padding:20px;margin-top:18px;display:none;}
.result-box.show{display:block;animation:fadeIn .3s ease;}
.result-label{font-size:.78rem;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;}
.result-value{font-family:var(--font-head);font-size:1.6rem;font-weight:700;color:var(--yellow);}
.steps-box{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:20px;margin-top:14px;}
.step{display:flex;gap:12px;margin-bottom:14px;animation:slideIn .4s ease both;}
.step-num{background:var(--yellow);color:#000;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.75rem;flex-shrink:0;}
.step-text{color:var(--text);font-size:.9rem;line-height:1.6;padding-top:2px;}
.step-text code{background:rgba(245,230,66,0.15);color:var(--yellow);padding:2px 8px;border-radius:6px;font-family:monospace;}
/* ===== BASIC CALC BUTTONS ===== */
.calc-display{background:#000;border:1px solid rgba(245,230,66,0.2);border-radius:12px;padding:20px 24px;text-align:right;font-family:monospace;font-size:2rem;color:var(--yellow);min-height:70px;margin-bottom:16px;word-break:break-all;}
.calc-display .expr{font-size:1rem;color:var(--muted);min-height:20px;}
.calc-buttons{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.calc-btn{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:18px;font-size:1rem;font-family:var(--font-head);font-weight:600;color:var(--text);cursor:pointer;transition:all .2s;}
.calc-btn:hover{background:rgba(245,230,66,0.12);border-color:var(--yellow);color:var(--yellow);}
.calc-btn.op{color:var(--yellow);}
.calc-btn.eq{background:var(--yellow);color:#000;grid-column:span 1;}
.calc-btn.eq:hover{background:var(--yellow2);}
.calc-btn.clr{color:#ff6b6b;}
/* ===== MATRIX ===== */
.matrix-grid{display:inline-grid;gap:8px;margin-bottom:16px;}
.matrix-input{width:60px;height:48px;background:rgba(255,255,255,0.05);border:1px solid rgba(245,230,66,0.18);border-radius:8px;text-align:center;color:var(--text);font-size:.9rem;outline:none;}
.matrix-input:focus{border-color:var(--yellow);}
/* ===== CHART CONTAINER ===== */
.chart-wrap{background:rgba(0,0,0,0.3);border-radius:12px;padding:20px;margin-top:16px;position:relative;}
.chart-wrap canvas{max-height:300px;}
/* ===== GPA METER ===== */
.gpa-meter{width:200px;height:200px;margin:0 auto 20px;position:relative;}
.gpa-meter svg{transform:rotate(-90deg);}
.gpa-meter .gpa-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;}
.gpa-text span{font-family:var(--font-head);font-size:2.2rem;font-weight:900;color:var(--yellow);}
.gpa-text small{display:block;color:var(--muted);font-size:.78rem;}
/* ===== SUBJECT TABLE ===== */
.subject-table{width:100%;border-collapse:collapse;margin-top:16px;}
.subject-table th{color:var(--yellow);font-size:.8rem;letter-spacing:.8px;text-transform:uppercase;padding:10px;text-align:left;border-bottom:1px solid rgba(245,230,66,0.2);}
.subject-table td{padding:10px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:.9rem;}
.subject-table tr:hover td{background:rgba(245,230,66,0.04);}
/* ===== HISTORY ===== */
.hist-entry{background:var(--card);border:1px solid var(--glass-border);border-radius:12px;padding:16px 20px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;transition:all .3s;}
.hist-entry:hover{border-color:rgba(245,230,66,0.3);}
.hist-entry .h-type{font-size:.75rem;color:var(--yellow);letter-spacing:.8px;text-transform:uppercase;margin-bottom:4px;}
.hist-entry .h-content{color:var(--text);font-size:.9rem;}
.hist-entry .h-time{color:var(--muted);font-size:.75rem;}
/* ===== ABOUT ===== */
.about-card{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius);padding:48px;backdrop-filter:blur(16px);text-align:center;max-width:800px;margin:0 auto;}
.about-card h3{font-family:var(--font-head);font-size:1.8rem;font-weight:900;color:var(--yellow);margin-bottom:20px;}
.about-card p{color:var(--muted);line-height:1.9;font-size:1rem;margin-bottom:16px;}
.motto-box{background:var(--yellow-dim);border:1px solid var(--glass-border);border-radius:16px;padding:28px;margin-top:28px;}
.motto-box p{font-family:var(--font-head);font-size:1.3rem;font-weight:700;color:var(--yellow);}
/* ===== TEAM ===== */
.team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:24px;max-width:1000px;margin:0 auto;}
.team-card{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:32px 20px;text-align:center;transition:all .4s;cursor:default;backdrop-filter:blur(12px);}
.team-card:hover{transform:translateY(-8px);border-color:var(--yellow);box-shadow:0 20px 60px rgba(245,230,66,0.12);}
.team-avatar{width:80px;height:80px;border-radius:50%;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;font-size:2.2rem;border:2px solid var(--glass-border);background:rgba(245,230,66,0.08);}
.team-card:hover .team-avatar{border-color:var(--yellow);}
.team-name{font-family:var(--font-head);font-weight:700;color:var(--text);font-size:.95rem;}
.team-role{color:var(--muted);font-size:.78rem;margin-top:4px;}
/* ===== AI ASSISTANT ===== */
#aiBtn{position:fixed;bottom:30px;right:30px;z-index:999;width:60px;height:60px;border-radius:50%;background:var(--yellow);border:none;cursor:pointer;font-size:1.6rem;box-shadow:0 0 30px var(--yellow-glow);transition:all .3s;animation:pulse2 2s ease-in-out infinite;}
#aiBtn:hover{transform:scale(1.1);}
#aiWindow{position:fixed;bottom:100px;right:30px;z-index:999;width:360px;max-height:520px;background:rgba(10,10,18,0.97);border:1px solid var(--glass-border);border-radius:24px;display:none;flex-direction:column;backdrop-filter:blur(24px);box-shadow:0 20px 80px rgba(0,0,0,0.7),0 0 40px rgba(245,230,66,0.1);}
#aiWindow.open{display:flex;animation:fadeIn .3s ease;}
.ai-header{padding:18px 20px;border-bottom:1px solid var(--glass-border);display:flex;justify-content:space-between;align-items:center;}
.ai-header h4{font-family:var(--font-head);font-weight:700;color:var(--yellow);font-size:.95rem;}
.ai-close{background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:1.2rem;transition:color .2s;}
.ai-close:hover{color:var(--yellow);}
.ai-messages{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px;max-height:340px;}
.ai-msg{padding:10px 14px;border-radius:14px;font-size:.87rem;max-width:85%;line-height:1.6;animation:fadeIn .3s ease;}
.ai-msg.bot{background:rgba(245,230,66,0.1);border:1px solid rgba(245,230,66,0.2);color:var(--text);align-self:flex-start;border-radius:14px 14px 14px 4px;}
.ai-msg.user{background:var(--yellow);color:#000;align-self:flex-end;border-radius:14px 14px 4px 14px;}
.ai-input-row{padding:12px 16px;border-top:1px solid var(--glass-border);display:flex;gap:8px;}
.ai-input-row input{flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(245,230,66,0.18);border-radius:10px;padding:10px 14px;color:var(--text);font-family:var(--font-body);font-size:.87rem;outline:none;}
.ai-input-row input:focus{border-color:var(--yellow);}
.ai-send{background:var(--yellow);color:#000;border:none;border-radius:10px;padding:10px 16px;cursor:pointer;font-weight:700;transition:all .2s;}
.ai-send:hover{background:var(--yellow2);}
/* ===== NOTICE MODAL ===== */
.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:9999;display:flex;align-items:center;justify-content:center;animation:fadeIn .3s ease;}
.modal-box{background:rgba(12,12,22,.98);border:1px solid var(--glass-border);border-radius:24px;padding:44px;max-width:440px;width:90%;text-align:center;backdrop-filter:blur(20px);box-shadow:0 0 60px rgba(245,230,66,0.15);}
.modal-box h3{font-family:var(--font-head);font-size:1.3rem;font-weight:700;color:var(--yellow);margin-bottom:16px;}
.modal-box p{color:var(--muted);line-height:1.8;font-size:.92rem;margin-bottom:24px;}
/* ===== EXPENSE TABLE ===== */
.expense-list{width:100%;border-collapse:collapse;}
.expense-list th{color:var(--yellow);font-size:.78rem;letter-spacing:.8px;text-transform:uppercase;padding:10px;border-bottom:1px solid rgba(245,230,66,0.2);}
.expense-list td{padding:10px;border-bottom:1px solid rgba(255,255,255,0.05);font-size:.88rem;}
/* ===== HABIT TRACKER ===== */
.habit-row{display:flex;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.05);}
.habit-row:last-child{border-bottom:none;}
.habit-check{width:20px;height:20px;accent-color:var(--yellow);cursor:pointer;}
.habit-label{flex:1;font-size:.9rem;}
.habit-streak{background:var(--yellow-dim);border:1px solid var(--glass-border);border-radius:6px;padding:2px 10px;font-size:.75rem;color:var(--yellow);}
/* ===== TODO ===== */
.todo-item{display:flex;align-items:center;gap:12px;padding:12px;background:rgba(255,255,255,0.03);border-radius:10px;margin-bottom:8px;transition:all .3s;}
.todo-item.done{opacity:.5;text-decoration:line-through;}
.todo-item .todo-del{margin-left:auto;background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:1rem;}
.todo-item .todo-del:hover{color:#ff6b6b;}
/* ===== FORMULA FINDER ===== */
.formula-cats{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;}
.fcat-btn{background:rgba(255,255,255,0.04);border:1px solid rgba(245,230,66,0.18);border-radius:30px;padding:7px 18px;font-size:.82rem;color:var(--muted);cursor:pointer;transition:all .3s;}
.fcat-btn:hover,.fcat-btn.active{background:var(--yellow-dim);border-color:var(--yellow);color:var(--yellow);}
.formula-card{background:var(--card);border:1px solid var(--glass-border);border-radius:var(--radius-sm);padding:24px;margin-bottom:14px;cursor:pointer;transition:all .3s;backdrop-filter:blur(12px);}
.formula-card:hover{border-color:var(--yellow);}
.formula-name{font-family:var(--font-head);font-weight:700;color:var(--yellow);margin-bottom:8px;}
.formula-eq{font-family:monospace;background:rgba(245,230,66,0.08);color:var(--yellow2);padding:8px 14px;border-radius:8px;font-size:1rem;margin-bottom:8px;display:inline-block;}
.formula-desc{color:var(--muted);font-size:.86rem;line-height:1.6;}
/* ===== CURRENCY ===== */
.currency-display{font-family:var(--font-head);font-size:2.5rem;font-weight:900;color:var(--yellow);text-align:center;margin:16px 0;}
/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:rgba(245,230,66,0.3);border-radius:4px;}
::-webkit-scrollbar-thumb:hover{background:var(--yellow);}
/* ===== KEYFRAMES ===== */
@keyframes floatY{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
@keyframes spin{to{transform:rotate(360deg);}}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
@keyframes pulse2{0%,100%{box-shadow:0 0 20px var(--yellow-glow);}50%{box-shadow:0 0 50px var(--yellow-glow);}}
@keyframes fadeQuote{0%{opacity:0;transform:translateY(10px);}20%{opacity:1;transform:translateY(0);}80%{opacity:1;transform:translateY(0);}100%{opacity:0;transform:translateY(-10px);}}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
@keyframes slideIn{from{opacity:0;transform:translateX(-10px);}to{opacity:1;transform:translateX(0);}}
@keyframes particleFloat{0%{transform:translateY(100vh) rotate(0deg);opacity:0;}10%{opacity:.6;}90%{opacity:.6;}100%{transform:translateY(-100px) rotate(720deg);opacity:0;}}
/* ===== RESPONSIVE ===== */
@media(max-width:900px){.cards-grid{grid-template-columns:1fr;}
.topbar{padding:14px 18px;}.topbar-nav{gap:4px;}.nav-btn{padding:6px 10px;font-size:.75rem;}
.inner-content{padding:20px 18px;}.dash-hero{padding:40px 18px 20px;}.dash-hero h2{font-size:1.8rem;}}
@media(max-width:480px){#aiWindow{width:calc(100vw - 20px);right:10px;}
.calc-buttons{grid-template-columns:repeat(4,1fr);gap:6px;}.calc-btn{padding:14px 8px;font-size:.85rem;}}
/* ===== PROGRESS BAR ===== */
.progress-bar-wrap{background:rgba(255,255,255,0.08);border-radius:8px;height:10px;overflow:hidden;margin-top:8px;}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(--yellow),var(--yellow2));border-radius:8px;transition:width .8s cubic-bezier(.23,1,.32,1);}
/* ===== TOOLTIP ===== */
.tip{font-size:.76rem;color:var(--muted);margin-top:6px;line-height:1.5;}
.badge{background:var(--yellow-dim);border:1px solid var(--glass-border);border-radius:6px;padding:2px 10px;font-size:.76rem;color:var(--yellow);display:inline-block;margin-top:6px;}
</style>
</head>
<body>

<!-- PARTICLES -->
<canvas id="particles"></canvas>

<!-- ======= LOGIN PAGE ======= -->
<div class="page active" id="loginPage">
  <div class="login-box">
    <div class="login-logo">
      <span class="star">✦</span>
      <h1>MATH GALAXY</h1>
      <p>Futuristic Calculator Platform</p>
    </div>
    <div class="form-group">
      <label>Your Name</label>
      <input type="text" id="loginName" placeholder="Enter your full name">
    </div>
    <div class="form-group">
      <label>Unique Number ID</label>
      <input type="text" id="loginId" placeholder="e.g. 12345">
    </div>
    <div class="form-group">
      <label>Age</label>
      <input type="number" id="loginAge" placeholder="Your age">
    </div>
    <div class="form-group">
      <label>Institution Name</label>
      <input type="text" id="loginInst" placeholder="Your college / university">
    </div>
    <button class="btn-login" onclick="doLogin()">✦ Enter Math Galaxy</button>
  </div>
</div>

<!-- ======= LOADING PAGE ======= -->
<div class="page" id="loadingPage">
  <div class="loading-orb"></div>
  <div class="loading-quote" id="loadingQuote">Mathematics is the language of the universe.</div>
  <div class="loading-bar-wrap"><div class="loading-bar" id="loadingBar"></div></div>
  <p style="color:var(--muted);font-size:.82rem;margin-top:10px">Initializing Math Galaxy...</p>
</div>

<!-- ======= DASHBOARD ======= -->
<div class="page" id="dashPage">
  <div class="topbar">
    <div class="topbar-logo">MATH <span>GALAXY</span> ✦</div>
    <div class="topbar-nav">
      <button class="nav-btn active" onclick="showSub('dashPage')">Home</button>
      <button class="nav-btn" onclick="showSub('histPage')">History</button>
      <button class="nav-btn" onclick="showSub('aboutPage')">About</button>
      <button class="nav-btn" onclick="showSub('teamPage')">Team</button>
      <button class="nav-btn" onclick="doLogout()">Logout</button>
    </div>
    <div class="user-badge" id="userBadge">✦ Guest</div>
  </div>
  <div class="dash-hero">
    <h2 id="dashWelcome">Welcome to Math Galaxy ✦</h2>
    <p id="dashSub">Your futuristic problem-solving platform</p>
  </div>
  <div class="cards-grid">
    <div class="main-card" onclick="openEngineering()">
      <span class="card-icon">⚙️</span>
      <div class="card-title">Engineering Calculator</div>
      <div class="card-desc">Advanced math tools — matrices, calculus, vectors, Laplace transforms, graph plotting and more.</div>
      <div class="card-arrow">→</div>
    </div>
    <div class="main-card" onclick="showSub('lifePage')">
      <span class="card-icon">🌍</span>
      <div class="card-title">Lifestyle Calculator</div>
      <div class="card-desc">Currency converter, expense tracker, BMI, calorie tracker, habit tracker and savings planner.</div>
      <div class="card-arrow">→</div>
    </div>
    <div class="main-card" onclick="showSub('studPage')">
      <span class="card-icon">🎓</span>
      <div class="card-title">Student Calculator</div>
      <div class="card-desc">GPA calculator, marks percentage, CGPA, study planner, college expense tracker.</div>
      <div class="card-arrow">→</div>
    </div>
  </div>
</div>

<!-- ======= ENGINEERING CALCULATOR PAGE ======= -->
<div class="page" id="calcPage">
  <div class="inner-header">
    <button class="back-btn" onclick="showSub('dashPage')">←</button>
    <h2>⚙️ Engineering Calculator</h2>
  </div>
  <div class="inner-content">
    <div class="tool-grid">
      <div class="tool-card" onclick="showCalc('basicCalc')"><div class="t-icon">🔢</div><div class="t-name">Basic Calculator</div></div>
      <div class="tool-card" onclick="showCalc('formulaFinder')"><div class="t-icon">📐</div><div class="t-name">Formula Finder</div></div>
      <div class="tool-card" onclick="showCalc('matrixCalc')"><div class="t-icon">🔳</div><div class="t-name">Matrix Calculator</div></div>
      <div class="tool-card" onclick="showCalc('eqSolver')"><div class="t-icon">⚡</div><div class="t-name">Equation Solver</div></div>
      <div class="tool-card" onclick="showCalc('calcSolver')"><div class="t-icon">∫</div><div class="t-name">Calculus Solver</div></div>
      <div class="tool-card" onclick="showCalc('vectorCalc')"><div class="t-icon">↗️</div><div class="t-name">Vector Algebra</div></div>
      <div class="tool-card" onclick="showCalc('laplaceCalc')"><div class="t-icon">🔄</div><div class="t-name">Laplace Transform</div></div>
      <div class="tool-card" onclick="showCalc('complexCalc')"><div class="t-icon">🌀</div><div class="t-name">Complex Numbers</div></div>
      <div class="tool-card" onclick="showCalc('probCalc')"><div class="t-icon">🎲</div><div class="t-name">Probability</div></div>
      <div class="tool-card" onclick="showCalc('primeCheck')"><div class="t-icon">🔑</div><div class="t-name">Prime Checker</div></div>
      <div class="tool-card" onclick="showCalc('unitConv')"><div class="t-icon">⚖️</div><div class="t-name">Unit Converter</div></div>
      <div class="tool-card" onclick="showCalc('graphPlot')"><div class="t-icon">📈</div><div class="t-name">Graph Plotter</div></div>
      <div class="tool-card" onclick="showCalc('eigenCalc')"><div class="t-icon">λ</div><div class="t-name">Eigenvalue Calc</div></div>
      <div class="tool-card" onclick="showCalc('crCalc')"><div class="t-icon">🔬</div><div class="t-name">Cauchy-Riemann</div></div>
    </div>

    <!-- BASIC CALCULATOR -->
    <div class="calc-panel" id="basicCalc">
      <h3>🔢 Basic Calculator</h3>
      <div class="calc-display"><div class="expr" id="bcExpr"></div><div id="bcDisp">0</div></div>
      <div class="calc-buttons">
        <button class="calc-btn clr" onclick="bcAction('C')">C</button>
        <button class="calc-btn op" onclick="bcAction('%')">%</button>
        <button class="calc-btn op" onclick="bcAction('//')">÷÷</button>
        <button class="calc-btn op" onclick="bcAction('/')">÷</button>
        <button class="calc-btn" onclick="bcAction('7')">7</button>
        <button class="calc-btn" onclick="bcAction('8')">8</button>
        <button class="calc-btn" onclick="bcAction('9')">9</button>
        <button class="calc-btn op" onclick="bcAction('*')">×</button>
        <button class="calc-btn" onclick="bcAction('4')">4</button>
        <button class="calc-btn" onclick="bcAction('5')">5</button>
        <button class="calc-btn" onclick="bcAction('6')">6</button>
        <button class="calc-btn op" onclick="bcAction('-')">−</button>
        <button class="calc-btn" onclick="bcAction('1')">1</button>
        <button class="calc-btn" onclick="bcAction('2')">2</button>
        <button class="calc-btn" onclick="bcAction('3')">3</button>
        <button class="calc-btn op" onclick="bcAction('+')">+</button>
        <button class="calc-btn" onclick="bcAction('0')" style="grid-column:span 2">0</button>
        <button class="calc-btn" onclick="bcAction('.')">.</button>
        <button class="calc-btn eq" onclick="bcAction('=')">＝</button>
      </div>
    </div>

    <!-- FORMULA FINDER -->
    <div class="calc-panel" id="formulaFinder">
      <h3>📐 Formula Finder</h3>
      <div class="inp-group" style="margin-bottom:18px">
        <input type="text" id="formulaSearch" placeholder="Search formulas..." oninput="filterFormulas()" style="width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(245,230,66,.18);border-radius:10px;padding:12px 16px;color:var(--text);font-family:var(--font-body);outline:none;">
      </div>
      <div class="formula-cats" id="formulaCats"></div>
      <div id="formulaList"></div>
    </div>

    <!-- MATRIX CALCULATOR -->
    <div class="calc-panel" id="matrixCalc">
      <h3>🔳 Matrix Calculator</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Size</label>
          <select id="matSize" onchange="buildMatrix()">
            <option value="2">2×2</option>
            <option value="3">3×3</option>
          </select>
        </div>
        <div class="inp-group">
          <label>Operation</label>
          <select id="matOp">
            <option value="det">Determinant</option>
            <option value="inv">Inverse</option>
            <option value="mul">Multiply A×B</option>
            <option value="add">Add A+B</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:16px" id="matrixInputs">
        <div><div style="color:var(--yellow);font-weight:700;margin-bottom:8px">Matrix A</div><div class="matrix-grid" id="matA"></div></div>
        <div><div style="color:var(--yellow);font-weight:700;margin-bottom:8px">Matrix B</div><div class="matrix-grid" id="matB"></div></div>
      </div>
      <button class="btn-calc" onclick="solveMatrix()">Calculate</button>
      <div class="result-box" id="matResult"></div>
    </div>

    <!-- EQUATION SOLVER -->
    <div class="calc-panel" id="eqSolver">
      <h3>⚡ Equation Solver</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Type</label>
          <select id="eqType">
            <option value="linear">Linear  ax + b = 0</option>
            <option value="quad">Quadratic  ax²+bx+c=0</option>
          </select>
        </div>
        <div class="inp-group"><label>a</label><input type="number" id="eqA" value="1"></div>
        <div class="inp-group"><label>b</label><input type="number" id="eqB" value="-3"></div>
        <div class="inp-group"><label>c (for quad)</label><input type="number" id="eqC" value="2"></div>
      </div>
      <button class="btn-calc" onclick="solveEq()">Solve</button>
      <div class="result-box" id="eqResult"></div>
    </div>

    <!-- CALCULUS SOLVER -->
    <div class="calc-panel" id="calcSolver">
      <h3>∫ Calculus Solver</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Operation</label>
          <select id="calcType">
            <option value="deriv">Derivative (power rule)</option>
            <option value="integ">Integral (power rule)</option>
            <option value="limit">Limit as x→c</option>
          </select>
        </div>
        <div class="inp-group"><label>Coefficient (a)</label><input type="number" id="calcA" value="3" placeholder="a in ax^n"></div>
        <div class="inp-group"><label>Power (n)</label><input type="number" id="calcN" value="2" placeholder="n in ax^n"></div>
        <div class="inp-group"><label>x→c (for limit)</label><input type="number" id="calcC" value="2"></div>
      </div>
      <button class="btn-calc" onclick="solveCalc()">Solve</button>
      <div class="result-box" id="calcResult"></div>
    </div>

    <!-- VECTOR ALGEBRA -->
    <div class="calc-panel" id="vectorCalc">
      <h3>↗️ Vector Algebra</h3>
      <div class="input-row">
        <div class="inp-group"><label>A: x</label><input type="number" id="vAx" value="1"></div>
        <div class="inp-group"><label>A: y</label><input type="number" id="vAy" value="2"></div>
        <div class="inp-group"><label>A: z</label><input type="number" id="vAz" value="3"></div>
      </div>
      <div class="input-row">
        <div class="inp-group"><label>B: x</label><input type="number" id="vBx" value="4"></div>
        <div class="inp-group"><label>B: y</label><input type="number" id="vBy" value="5"></div>
        <div class="inp-group"><label>B: z</label><input type="number" id="vBz" value="6"></div>
      </div>
      <div class="input-row">
        <div class="inp-group">
          <label>Operation</label>
          <select id="vecOp">
            <option value="add">Addition A+B</option>
            <option value="dot">Dot Product</option>
            <option value="cross">Cross Product</option>
            <option value="mag">Magnitude of A</option>
            <option value="unit">Unit Vector of A</option>
          </select>
        </div>
      </div>
      <button class="btn-calc" onclick="solveVec()">Calculate</button>
      <div class="result-box" id="vecResult"></div>
    </div>

    <!-- LAPLACE -->
    <div class="calc-panel" id="laplaceCalc">
      <h3>🔄 Laplace Transform</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Common Functions</label>
          <select id="lapFunc">
            <option value="1">f(t) = 1</option>
            <option value="t">f(t) = t</option>
            <option value="t2">f(t) = t²</option>
            <option value="tn">f(t) = tⁿ</option>
            <option value="eat">f(t) = e^(at)</option>
            <option value="sinat">f(t) = sin(at)</option>
            <option value="cosat">f(t) = cos(at)</option>
            <option value="teat">f(t) = t·e^(at)</option>
          </select>
        </div>
        <div class="inp-group"><label>Parameter (a/n)</label><input type="number" id="lapA" value="2"></div>
      </div>
      <button class="btn-calc" onclick="solveLaplace()">Find Transform</button>
      <div class="result-box" id="lapResult"></div>
    </div>

    <!-- COMPLEX -->
    <div class="calc-panel" id="complexCalc">
      <h3>🌀 Complex Number Converter</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Mode</label>
          <select id="cxMode">
            <option value="topolar">Rectangular → Polar</option>
            <option value="torect">Polar → Rectangular</option>
          </select>
        </div>
        <div class="inp-group"><label>Value 1 (a or r)</label><input type="number" id="cxV1" value="3"></div>
        <div class="inp-group"><label>Value 2 (b or θ°)</label><input type="number" id="cxV2" value="4"></div>
      </div>
      <button class="btn-calc" onclick="solveComplex()">Convert</button>
      <div class="result-box" id="cxResult"></div>
    </div>

    <!-- PROBABILITY -->
    <div class="calc-panel" id="probCalc">
      <h3>🎲 Probability Calculator</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Type</label>
          <select id="probType">
            <option value="basic">Basic P(A)</option>
            <option value="comb">Combinations C(n,r)</option>
            <option value="perm">Permutations P(n,r)</option>
            <option value="binom">Binomial P(X=k)</option>
          </select>
        </div>
        <div class="inp-group"><label>n (total)</label><input type="number" id="probN" value="10"></div>
        <div class="inp-group"><label>r / k</label><input type="number" id="probR" value="3"></div>
        <div class="inp-group"><label>p (for binomial)</label><input type="number" id="probP" value="0.5" step="0.1" min="0" max="1"></div>
      </div>
      <button class="btn-calc" onclick="solveProb()">Calculate</button>
      <div class="result-box" id="probResult"></div>
    </div>

    <!-- PRIME CHECKER -->
    <div class="calc-panel" id="primeCheck">
      <h3>🔑 Prime Number Checker</h3>
      <div class="input-row">
        <div class="inp-group"><label>Number</label><input type="number" id="primeNum" value="17"></div>
      </div>
      <button class="btn-calc" onclick="checkPrime()">Check</button>
      <div class="result-box" id="primeResult"></div>
    </div>

    <!-- UNIT CONVERTER -->
    <div class="calc-panel" id="unitConv">
      <h3>⚖️ Unit Converter</h3>
      <div class="input-row">
        <div class="inp-group">
          <label>Category</label>
          <select id="unitCat" onchange="updateUnitSelects()">
            <option value="length">Length</option>
            <option value="mass">Mass</option>
            <option value="temp">Temperature</option>
            <option value="area">Area</option>
            <option value="volume">Volume</option>
            <option value="speed">Speed</option>
            <option value="time">Time</option>
          </select>
        </div>
        <div class="inp-group"><label>From</label><select id="unitFrom"></select></div>
        <div class="inp-group"><label>To</label><select id="unitTo"></select></div>
        <div class="inp-group"><label>Value</label><input type="number" id="unitVal" value="1"></div>
      </div>
      <button class="btn-calc" onclick="convertUnit()">Convert</button>
      <div class="result-box" id="unitResult"></div>
    </div>

    <!-- GRAPH PLOTTER -->
    <div class="calc-panel" id="graphPlot">
      <h3>📈 Graph Plotter</h3>
      <div class="input-row">
        <div class="inp-group"><label>Function f(x)</label><input type="text" id="graphFunc" value="Math.sin(x)" placeholder="e.g. Math.sin(x), x*x"></div>
        <div class="inp-group"><label>x from</label><input type="number" id="graphXmin" value="-10"></div>
        <div class="inp-group"><label>x to</label><input type="number" id="graphXmax" value="10"></div>
      </div>
      <button class="btn-calc" onclick="plotGraph()">Plot</button>
      <div class="chart-wrap"><canvas id="graphCanvas"></canvas></div>
    </div>

    <!-- EIGENVALUE -->
    <div class="calc-panel" id="eigenCalc">
      <h3>λ Eigenvalue Calculator (2×2)</h3>
      <p class="tip" style="margin-bottom:16px">For matrix [[a,b],[c,d]], eigenvalues λ satisfy: λ² - (a+d)λ + (ad-bc) = 0</p>
      <div id="eigenInputs">
        <div style="display:flex;gap:8px;margin-bottom:8px">
          <input class="matrix-input" id="eig00" value="4"> <input class="matrix-input" id="eig01" value="1">
        </div>
        <div style="display:flex;gap:8px">
          <input class="matrix-input" id="eig10" value="2"> <input class="matrix-input" id="eig11" value="3">
        </div>
      </div>
      <button class="btn-calc" onclick="solveEigen()" style="margin-top:16px">Find Eigenvalues</button>
      <div class="result-box" id="eigenResult"></div>
    </div>

    <!-- CAUCHY-RIEMANN -->
    <div class="calc-panel" id="crCalc">
      <h3>🔬 Cauchy-Riemann Equation Checker</h3>
      <p class="tip" style="margin-bottom:16px">Enter partial derivatives of u and v for f(z) = u + iv. CR conditions: ∂u/∂x = ∂v/∂y and ∂u/∂y = −∂v/∂x</p>
      <div class="input-row">
        <div class="inp-group"><label>∂u/∂x</label><input type="number" id="crUx" value="2"></div>
        <div class="inp-group"><label>∂u/∂y</label><input type="number" id="crUy" value="-3"></div>
        <div class="inp-group"><label>∂v/∂x</label><input type="number" id="crVx" value="3"></div>
        <div class="inp-group"><label>∂v/∂y</label><input type="number" id="crVy" value="2"></div>
      </div>
      <button class="btn-calc" onclick="checkCR()">Check</button>
      <div class="result-box" id="crResult"></div>
    </div>
  </div>
</div>

<!-- ======= LIFESTYLE PAGE ======= -->
<div class="page" id="lifePage">
  <div class="inner-header">
    <button class="back-btn" onclick="showSub('dashPage')">←</button>
    <h2>🌍 Lifestyle Calculator</h2>
  </div>
  <div class="inner-content">
    <div class="tool-grid">
      <div class="tool-card" onclick="showCalc('currencyConv')"><div class="t-icon">💱</div><div class="t-name">Currency Converter</div></div>
      <div class="tool-card" onclick="showCalc('expenseTracker')"><div class="t-icon">💸</div><div class="t-name">Expense Tracker</div></div>
      <div class="tool-card" onclick="showCalc('electricBill')"><div class="t-icon">⚡</div><div class="t-name">Electricity Bill</div></div>
      <div class="tool-card" onclick="showCalc('budgetCalc')"><div class="t-icon">🏠</div><div class="t-name">Household Budget</div></div>
      <div class="tool-card" onclick="showCalc('todoPlanner')"><div class="t-icon">✅</div><div class="t-name">Daily Planner</div></div>
      <div class="tool-card" onclick="showCalc('bmiCalc')"><div class="t-icon">⚖️</div><div class="t-name">BMI & Calorie</div></div>
      <div class="tool-card" onclick="showCalc('habitTracker')"><div class="t-icon">🌟</div><div class="t-name">Habit Tracker</div></div>
      <div class="tool-card" onclick="showCalc('licCalc')"><div class="t-icon">💰</div><div class="t-name">LIC Savings</div></div>
    </div>

    <!-- CURRENCY CONVERTER -->
    <div class="calc-panel" id="currencyConv">
      <h3>💱 Global Currency Converter</h3>
      <div class="input-row">
        <div class="inp-group"><label>Amount</label><input type="number" id="curAmt" value="100"></div>
        <div class="inp-group">
          <label>From</label>
          <select id="curFrom"></select>
        </div>
        <div class="inp-group">
          <label>To</label>
          <select id="curTo"></select>
