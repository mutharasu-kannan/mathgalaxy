async function sendAI(){
  const input=document.getElementById('aiInput');
  const query=input.value.trim();
  if(!query)return;
  input.value='';
  const msgs=document.getElementById('aiMessages');
  msgs.innerHTML+=`<div class="ai-msg user">${query}</div>`;
  msgs.scrollTop=msgs.scrollHeight;
  // Show typing
  const typingId='typing_'+Date.now();
  msgs.innerHTML+=`<div class="ai-msg bot" id="${typingId}">✦ Thinking...</div>`;
  msgs.scrollTop=msgs.scrollHeight;

  // Try built-in knowledge base first
  const lower=query.toLowerCase();
  let found='';
  for(const [key,val] of Object.entries(AI_KB)){
    if(lower.includes(key)){found=val;break;}
  }

  // Call Anthropic API
  try{
    const response=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system:'You are Math Galaxy AI, a friendly math and engineering assistant for college students. Give concise, helpful answers about mathematics, formulas, and calculations. Use simple language. Keep responses under 150 words.',
        messages:[{role:'user',content:query}]
      })
    });
    const data=await response.json();
    const reply=data.content?.[0]?.text||found||'I can help with math questions! Try asking about derivatives, matrices, GPA calculations, or any formula.';
    document.getElementById(typingId).textContent=reply;
  }catch(e){
    const fallback=found||'I can help with math! Ask me about formulas, how to use a calculator, or explain any concept. Try: "What is the quadratic formula?" or "How to calculate GPA?"';
    document.getElementById(typingId).textContent=fallback;
  }
  msgs.scrollTop=msgs.scrollHeight;
}

