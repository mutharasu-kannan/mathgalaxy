// ===== MATRIX CALCULATOR =====
function buildMatrix(){
  const n=parseInt(document.getElementById('matSize').value);
  ['matA','matB'].forEach(id=>{
    const el=document.getElementById(id);
    el.style.gridTemplateColumns=`repeat(${n},60px)`;
    let html='';
    for(let i=0;i<n;i++)for(let j=0;j<n;j++)html+=`<input class="matrix-input" id="${id}_${i}_${j}" value="${i===j?1:0}" type="number">`;
    el.innerHTML=html;
  });
}
function getMatrix(id,n){return Array.from({length:n},(_,i)=>Array.from({length:n},(_,j)=>parseFloat(document.getElementById(`${id}_${i}_${j}`).value)||0));}
function det2(m){return m[0][0]*m[1][1]-m[0][1]*m[1][0];}
function det3(m){return m[0][0]*(m[1][1]*m[2][2]-m[1][2]*m[2][1])-m[0][1]*(m[1][0]*m[2][2]-m[1][2]*m[2][0])+m[0][2]*(m[1][0]*m[2][1]-m[1][1]*m[2][0]);}
function matStr(m){return m.map(r=>'['+r.join(', ')+']').join('\n');}
function solveMatrix(){
  const n=parseInt(document.getElementById('matSize').value);
  const op=document.getElementById('matOp').value;
  const A=getMatrix('matA',n),B=getMatrix('matB',n);
  let html='<div class="result-label">Result</div>';
  const steps=[];
  if(op==='det'){
    const d=n===2?det2(A):det3(A);
    steps.push({n:1,t:'Identify the matrix A'});
    steps.push({n:2,t:'Apply the '+n+'×'+n+' determinant formula'});
    steps.push({n:3,t:`det(A) = <code>${d.toFixed(4)}</code>`});
    html+=`<div class="result-value">det = ${d.toFixed(4)}</div>`;
    addHistory('Matrix','det(A) = '+d.toFixed(4));
  }else if(op==='mul'||op==='add'){
    const C=Array.from({length:n},(_,i)=>Array.from({length:n},(_,j)=>op==='mul'?A[i].reduce((s,_,k)=>s+A[i][k]*B[k][j],0):A[i][j]+B[i][j]));
    html+=`<pre style="color:var(--yellow);font-size:.9rem;line-height:1.6">${matStr(C)}</pre>`;
    steps.push({n:1,t:'Take matrices A and B'});
    steps.push({n:2,t:op==='mul'?'Multiply row by column for each element':'Add corresponding elements'});
    steps.push({n:3,t:`Result: <code>${matStr(C).replace(/\n/g,' ')}</code>`});
    addHistory('Matrix',op.toUpperCase()+' result computed');
  }else if(op==='inv'&&n===2){
    const d=det2(A);
    if(Math.abs(d)<1e-10){html+='<div class="result-value" style="color:#ff6b6b">Not invertible (det=0)</div>';}
    else{
      const inv=[[A[1][1]/d,-A[0][1]/d],[-A[1][0]/d,A[0][0]/d]];
      html+=`<pre style="color:var(--yellow);font-size:.9rem;line-height:1.6">${matStr(inv.map(r=>r.map(v=>v.toFixed(3))))}</pre>`;
      steps.push({n:1,t:`det(A) = <code>${d.toFixed(4)}</code>`});
      steps.push({n:2,t:'Apply formula A⁻¹ = (1/det)·adj(A)'});
      steps.push({n:3,t:`Inverse computed above`});
      addHistory('Matrix','Inverse computed');
    }
  }
  const rb=document.getElementById('matResult');
  rb.className='result-box show';
  rb.innerHTML=html+'<div class="steps-box">'+steps.map(s=>`<div class="step"><div class="step-num">${s.n}</div><div class="step-text">${s.t}</div></div>`).join('')+'</div>';
}

// ===== EQUATION SOLVER =====
function solveEq(){
  const type=document.getElementById('eqType').value;
  const a=parseFloat(document.getElementById('eqA').value);
  const b=parseFloat(document.getElementById('eqB').value);
  const c=parseFloat(document.getElementById('eqC').value);
  let html='<div class="result-label">Solution</div>';
  let steps=[];
  if(type==='linear'){
    const x=-b/a;
    steps=[{n:1,t:`Equation: <code>${a}x + ${b} = 0</code>`},{n:2,t:`Move constant: <code>${a}x = ${-b}</code>`},{n:3,t:`Divide: <code>x = ${-b}/${a} = ${x.toFixed(4)}</code>`}];
    html+=`<div class="result-value">x = ${x.toFixed(4)}</div>`;
    addHistory('Equation Solver',`${a}x+${b}=0 → x=${x.toFixed(4)}`);
  }else{
    const disc=b*b-4*a*c;
    steps=[{n:1,t:`Equation: <code>${a}x²+${b}x+${c}=0</code>`},{n:2,t:`Discriminant Δ = b²-4ac = <code>${disc.toFixed(4)}</code>`}];
    if(disc<0){
      const real=-b/(2*a),imag=Math.sqrt(-disc)/(2*a);
      steps.push({n:3,t:`Complex roots: <code>x = ${real.toFixed(3)} ± ${imag.toFixed(3)}i</code>`});
      html+=`<div class="result-value">x = ${real.toFixed(3)} ± ${imag.toFixed(3)}i</div>`;
    }else{
      const x1=(-b+Math.sqrt(disc))/(2*a),x2=(-b-Math.sqrt(disc))/(2*a);
      steps.push({n:3,t:`x₁ = <code>${x1.toFixed(4)}</code>, x₂ = <code>${x2.toFixed(4)}</code>`});
      html+=`<div class="result-value">x₁ = ${x1.toFixed(4)}, x₂ = ${x2.toFixed(4)}</div>`;
      addHistory('Equation Solver',`${a}x²+${b}x+${c}=0 → x₁=${x1.toFixed(3)}, x₂=${x2.toFixed(3)}`);
    }
  }
  const rb=document.getElementById('eqResult');
  rb.className='result-box show';
  rb.innerHTML=html+'<div class="steps-box">'+steps.map(s=>`<div class="step"><div class="step-num">${s.n}</div><div class="step-text">${s.t}</div></div>`).join('')+'</div>';
}

// ===== CALCULUS SOLVER =====
function solveCalc(){
  const type=document.getElementById('calcType').value;
  const a=parseFloat(document.getElementById('calcA').value);
  const n=parseFloat(document.getElementById('calcN').value);
  const cv=parseFloat(document.getElementById('calcC').value);
  let html='<div class="result-label">Result</div>';
  let steps=[];
  if(type==='deriv'){
    const newCoeff=a*n,newPow=n-1;
    steps=[{n:1,t:`Function: <code>f(x) = ${a}x^${n}</code>`},{n:2,t:`Apply power rule: d/dx[axⁿ] = n·a·xⁿ⁻¹`},{n:3,t:`f\'(x) = <code>${newCoeff}x^${newPow}</code>`}];
    html+=`<div class="result-value">f\'(x) = ${newCoeff}x^${newPow}</div>`;
    addHistory('Calculus',`d/dx[${a}x^${n}] = ${newCoeff}x^${newPow}`);
  }else if(type==='integ'){
    const newCoeff=(a/(n+1)),newPow=n+1;
    steps=[{n:1,t:`Function: <code>f(x) = ${a}x^${n}</code>`},{n:2,t:`Apply power rule: ∫axⁿ dx = axⁿ⁺¹/(n+1) + C`},{n:3,t:`∫f dx = <code>${newCoeff.toFixed(4)}x^${newPow} + C</code>`}];
    html+=`<div class="result-value">${newCoeff.toFixed(4)}x^${newPow} + C</div>`;
    addHistory('Calculus',`∫${a}x^${n}dx = ${newCoeff.toFixed(4)}x^${newPow}+C`);
  }else{
    const val=a*Math.pow(cv,n);
    steps=[{n:1,t:`lim(x→${cv}) of <code>${a}x^${n}</code>`},{n:2,t:`Substitute x = ${cv}`},{n:3,t:`= ${a}·(${cv})^${n} = <code>${val.toFixed(4)}</code>`}];
    html+=`<div class="result-value">${val.toFixed(4)}</div>`;
    addHistory('Calculus',`lim(x→${cv}) ${a}x^${n} = ${val.toFixed(4)}`);
  }
  const rb=document.getElementById('calcResult');
  rb.className='result-box show';
  rb.innerHTML=html+'<div class="steps-box">'+steps.map(s=>`<div class="step"><div class="step-num">${s.n}</div><div class="step-text">${s.t}</div></div>`).join('')+'</div>';
}

// ===== VECTOR =====
function solveVec(){
  const ax=+document.getElementById('vAx').value,ay=+document.getElementById('vAy').value,az=+document.getElementById('vAz').value;
  const bx=+document.getElementById('vBx').value,by=+document.getElementById('vBy').value,bz=+document.getElementById('vBz').value;
  const op=document.getElementById('vecOp').value;
  let html='<div class="result-label">Result</div>';
  let steps=[];
  if(op==='add'){
    const r=[ax+bx,ay+by,az+bz];
    steps=[{n:1,t:`A = <code>(${ax},${ay},${az})</code>, B = <code>(${bx},${by},${bz})</code>`},{n:2,t:'Add component-wise'},{n:3,t:`A+B = <code>(${r[0]},${r[1]},${r[2]})</code>`}];
    html+=`<div class="result-value">(${r[0]}, ${r[1]}, ${r[2]})</div>`;
    addHistory('Vector','A+B = ('+r.join(',')+')');
  }else if(op==='dot'){
    const d=ax*bx+ay*by+az*bz;
    steps=[{n:1,t:`A·B = AₓBₓ + AᵧBᵧ + A_zB_z`},{n:2,t:`= ${ax*bx} + ${ay*by} + ${az*bz}`},{n:3,t:`= <code>${d}</code>`}];
    html+=`<div class="result-value">${d}</div>`;
    addHistory('Vector','A·B = '+d);
  }else if(op==='cross'){
    const r=[ay*bz-az*by,az*bx-ax*bz,ax*by-ay*bx];
    steps=[{n:1,t:'Apply determinant formula for cross product'},{n:2,t:`i: ${ay}×${bz}-${az}×${by} = ${r[0]}`},{n:3,t:`A×B = <code>(${r[0]}, ${r[1]}, ${r[2]})</code>`}];
    html+=`<div class="result-value">(${r[0]}, ${r[1]}, ${r[2]})</div>`;
    addHistory('Vector','A×B = ('+r.join(',')+')');
  }else if(op==='mag'){
    const m=Math.sqrt(ax*ax+ay*ay+az*az);
    steps=[{n:1,t:`|A| = √(${ax}² + ${ay}² + ${az}²)`},{n:2,t:`= √${ax*ax+ay*ay+az*az}`},{n:3,t:`= <code>${m.toFixed(4)}</code>`}];
    html+=`<div class="result-value">|A| = ${m.toFixed(4)}</div>`;
    addHistory('Vector','|A| = '+m.toFixed(4));
  }else if(op==='unit'){
    const m=Math.sqrt(ax*ax+ay*ay+az*az);
    const u=[ax/m,ay/m,az/m];
    html+=`<div class="result-value">(${u[0].toFixed(3)}, ${u[1].toFixed(3)}, ${u[2].toFixed(3)})</div>`;
    addHistory('Vector','Unit A = ('+u.map(v=>v.toFixed(3)).join(',')+')');
  }
  const rb=document.getElementById('vecResult');
  rb.className='result-box show';
  rb.innerHTML=html+'<div class="steps-box">'+steps.map(s=>`<div class="step"><div class="step-num">${s.n}</div><div class="step-text">${s.t}</div></div>`).join('')+'</div>';
}

