let bcExpr='',bcFresh=false;
function bcAction(v){
  const disp=document.getElementById('bcDisp');
  const exprEl=document.getElementById('bcExpr');
  if(v==='C'){bcExpr='';disp.textContent='0';exprEl.textContent='';bcFresh=false;return;}
  if(v==='='){
    try{
      let ex=bcExpr.replace(/×/g,'*').replace(/÷÷/g,'Math.floor(').replace(/÷/g,'/').replace(/%/g,'*0.01');
      if(bcExpr.includes('÷÷'))ex+='/'+bcExpr.split('÷÷')[1]+')';
      const res=Function('return '+ex)();
      exprEl.textContent=bcExpr+'=';
      disp.textContent=res;
      addHistory('Basic Calc',bcExpr+' = '+res);
      bcExpr=String(res);bcFresh=true;
    }catch(e){disp.textContent='Error';bcExpr='';}
    return;
  }
  if(bcFresh&&!'+-*/÷×%'.includes(v)){bcExpr='';}
  bcFresh=false;
  bcExpr+=v;
  exprEl.textContent=bcExpr;
  disp.textContent=v;
}

