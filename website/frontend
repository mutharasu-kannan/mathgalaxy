// ===== PROBABILITY =====
function factorial(n){if(n<=1)return 1;let r=1;for(let i=2;i<=n;i++)r*=i;return r;}
function comb(n,r){if(r>n)return 0;return factorial(n)/(factorial(r)*factorial(n-r));}
function solveProb(){
  const type=document.getElementById('probType').value;
  const n=parseFloat(document.getElementById('probN').value);
  const r=parseFloat(document.getElementById('probR').value);
  const p=parseFloat(document.getElementById('probP').value);
  const rb=document.getElementById('probResult');
  let html='<div class="result-label">Result</div>';
  if(type==='basic'){const res=r/n;html+=`<div class="result-value">P = ${res.toFixed(4)}</div>`;addHistory('Probability',`P=${r}/${n}=${res.toFixed(4)}`);}
  else if(type==='comb'){const res=comb(n,r);html+=`<div class="result-value">C(${n},${r}) = ${res}</div>`;addHistory('Probability',`C(${n},${r})=${res}`);}
  else if(type==='perm'){const res=factorial(n)/factorial(n-r);html+=`<div class="result-value">P(${n},${r}) = ${res}</div>`;addHistory('Probability',`P(${n},${r})=${res}`);}
  else{const res=comb(n,r)*Math.pow(p,r)*Math.pow(1-p,n-r);html+=`<div class="result-value">P(X=${r}) = ${res.toFixed(6)}</div>`;addHistory('Probability',`Binomial P(X=${r})=${res.toFixed(6)}`);}
  rb.className='result-box show';rb.innerHTML=html;
}

