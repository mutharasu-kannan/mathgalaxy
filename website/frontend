// ===== EIGENVALUE =====
function solveEigen(){
  const a=parseFloat(document.getElementById('eig00').value);
  const b=parseFloat(document.getElementById('eig01').value);
  const c=parseFloat(document.getElementById('eig10').value);
  const d=parseFloat(document.getElementById('eig11').value);
  const trace=a+d,det=a*d-b*c;
  const disc=trace*trace-4*det;
  const rb=document.getElementById('eigenResult');
  let html='<div class="result-label">Eigenvalues</div>';
  if(disc>=0){
    const l1=(trace+Math.sqrt(disc))/2,l2=(trace-Math.sqrt(disc))/2;
    html+=`<div class="result-value">λ₁ = ${l1.toFixed(4)}, λ₂ = ${l2.toFixed(4)}</div>`;
    addHistory('Eigenvalue',`λ₁=${l1.toFixed(3)}, λ₂=${l2.toFixed(3)}`);
  }else{
    const re=trace/2,im=Math.sqrt(-disc)/2;
    html+=`<div class="result-value">λ = ${re.toFixed(4)} ± ${im.toFixed(4)}i</div>`;
    addHistory('Eigenvalue',`λ = ${re.toFixed(3)} ± ${im.toFixed(3)}i`);
  }
  html+=`<div class="steps-box"><div class="step"><div class="step-num">1</div><div class="step-text">Characteristic equation: <code>λ² - trace·λ + det = 0</code></div></div><div class="step"><div class="step-num">2</div><div class="step-text">trace = ${trace}, det = ${det.toFixed(4)}</div></div><div class="step"><div class="step-num">3</div><div class="step-text">Discriminant = ${disc.toFixed(4)}</div></div></div>`;
  rb.className='result-box show';rb.innerHTML=html;
}

