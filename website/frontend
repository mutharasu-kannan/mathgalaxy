  const pct=(obt/tot)*100;
  let grade='';
  if(pct>=90)grade='O (Outstanding)';else if(pct>=80)grade='A+ (Excellent)';else if(pct>=70)grade='A (Very Good)';else if(pct>=60)grade='B+ (Good)';else if(pct>=50)grade='B (Above Average)';else if(pct>=40)grade='C (Average)';else grade='RA/F (Fail)';
  const rb=document.getElementById('mksResult');
  rb.className='result-box show';
  rb.innerHTML=`<div class="result-label">Percentage</div><div class="result-value">${pct.toFixed(2)}% — ${grade}</div><div class="steps-box"><div class="step"><div class="step-num">1</div><div class="step-text">% = (Obtained/Total)×100 = <code>(${obt}/${tot})×100</code></div></div><div class="step"><div class="step-num">2</div><div class="step-text">= <code>${pct.toFixed(2)}%</code></div></div><div class="step"><div class="step-num">3</div><div class="step-text">Grade: <code>${grade}</code></div></div></div>`;
  addHistory('Marks %',obt+'/'+tot+' = '+pct.toFixed(2)+'%');
}

// ===== GPA CALCULATOR =====
const GRADE_MAP={O:10,'A+':9,A:8,'B+':7,B:6,C:5,'RA/F':0};
function initGpaSubjects(){
  const d=getUserData();
  if(!(d.gpaSubjects||[]).length){d.gpaSubjects=[{name:'Subject 1',credits:4,grade:'O'},{name:'Subject 2',credits:3,grade:'A+'}];saveUserData(d);}
}
function renderGpaSubjects(){
  const d=getUserData();const subs=d.gpaSubjects||[];
  document.getElementById('gpaSubjects').innerHTML=subs.map((s,i)=>`<div class="input-row" style="margin-bottom:10px"><div class="inp-group"><label>Subject</label><input type="text" value="${s.name}" oninput="updateGpaSub(${i},'name',this.value)"></div><div class="inp-group"><label>Credits</label><input type="number" value="${s.credits}" min="1" max="6" oninput="updateGpaSub(${i},'credits',this.value)"></div><div class="inp-group"><label>Grade</label><select onchange="updateGpaSub(${i},'grade',this.value)">${Object.keys(GRADE_MAP).map(g=>`<option value="${g}" ${s.grade===g?'selected':''}>${g} (${GRADE_MAP[g]})</option>`).join('')}</select></div></div>`).join('');
}
function addGpaSubject(){
  const d=getUserData();d.gpaSubjects=d.gpaSubjects||[];
  d.gpaSubjects.push({name:'Subject '+(d.gpaSubjects.length+1),credits:3,grade:'A'});
  saveUserData(d);renderGpaSubjects();
}
function updateGpaSub(i,k,v){
  const d=getUserData();d.gpaSubjects[i][k]=k==='credits'?parseInt(v):v;saveUserData(d);
}
function calcGPA(){
  const d=getUserData();const subs=d.gpaSubjects||[];
  const total=subs.reduce((s,sub)=>s+(GRADE_MAP[sub.grade]*(sub.credits||0)),0);
  const totalCredits=subs.reduce((s,sub)=>s+(sub.credits||0),0);
  const gpa=totalCredits?total/totalCredits:0;
  document.getElementById('gpaVal').textContent=gpa.toFixed(2);
  const circle=document.getElementById('gpaMeterCircle');
  const offset=314-(314*(gpa/10));
  circle.style.strokeDashoffset=offset;
  document.getElementById('gpaTableBody').innerHTML=subs.map(s=>`<tr><td>${s.name}</td><td>${s.credits}</td><td>${s.grade}</td><td>${GRADE_MAP[s.grade]*s.credits}</td></tr>`).join('');
  document.getElementById('gpaResult').className='result-box show';
  addHistory('GPA','GPA = '+gpa.toFixed(2));
}

// ===== CGPA =====
function initCgpaSems(){
  const d=getUserData();
  if(!(d.cgpaSems||[]).length){d.cgpaSems=[{name:'Semester 1',gpa:8.5,credits:24}];saveUserData(d);}
}
function renderCgpaSems(){
  const d=getUserData();const sems=d.cgpaSems||[];
  document.getElementById('cgpaSems').innerHTML=sems.map((s,i)=>`<div class="input-row"><div class="inp-group"><label>Semester</label><input type="text" value="${s.name}" oninput="updateCgpaSem(${i},'name',this.value)"></div><div class="inp-group"><label>GPA</label><input type="number" value="${s.gpa}" step="0.01" max="10" oninput="updateCgpaSem(${i},'gpa',this.value)"></div><div class="inp-group"><label>Credits</label><input type="number" value="${s.credits}" oninput="updateCgpaSem(${i},'credits',this.value)"></div></div>`).join('');
}
function addCgpaSem(){
  const d=getUserData();d.cgpaSems=d.cgpaSems||[];
  d.cgpaSems.push({name:'Semester '+(d.cgpaSems.length+1),gpa:8.0,credits:24});
  saveUserData(d);renderCgpaSems();
}
function updateCgpaSem(i,k,v){
  const d=getUserData();d.cgpaSems[i][k]=k==='name'?v:parseFloat(v);saveUserData(d);
}
function calcCGPA(){
  const d=getUserData();const sems=d.cgpaSems||[];
  const total=sems.reduce((s,sem)=>s+(sem.gpa*sem.credits),0);
  const totalC=sems.reduce((s,sem)=>s+sem.credits,0);
  const cgpa=totalC?total/totalC:0;
  const rb=document.getElementById('cgpaResult');
  rb.className='result-box show';
  rb.innerHTML=`<div class="result-label">CGPA</div><div class="result-value">${cgpa.toFixed(2)} / 10</div><div class="tip">Total Credits: ${totalC}</div>`;
  addHistory('CGPA','CGPA = '+cgpa.toFixed(2));
}

// ===== GPA TO PCT =====
function convertGpa(){
  const gpa=parseFloat(document.getElementById('gpa2pct').value);
  const pct=(gpa-0.5)*10;
  const rb=document.getElementById('gpa2pctResult');
  rb.className='result-box show';
  rb.innerHTML=`<div class="result-label">Percentage (approx)</div><div class="result-value">${pct.toFixed(2)}%</div><div class="tip">Formula: % ≈ (GPA - 0.5) × 10</div>`;
  addHistory('GPA→%',gpa+' GPA = '+pct.toFixed(2)+'%');
}

// ===== STUDY PROGRESS =====
function addStudProgress(){
  const sub=document.getElementById('studSub').value.trim();
  const done=parseInt(document.getElementById('studDone').value);
  const total=parseInt(document.getElementById('studTotal').value);
  if(!sub)return;
  const d=getUserData();d.studProgress=d.studProgress||[];
  const idx=d.studProgress.findIndex(s=>s.sub===sub);
  if(idx>=0)d.studProgress[idx]={sub,done,total};
  else d.studProgress.push({sub,done,total});
  saveUserData(d);
  renderStudProgress();
  addHistory('Study Progress',sub+': '+done+'/'+total);
}
function renderStudProgress(){
  const d=getUserData();const list=d.studProgress||[];
  document.getElementById('studProgressList').innerHTML=list.map(s=>{
    const pct=Math.round(s.done/s.total*100);
    return`<div style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="color:var(--text)">${s.sub}</span><span style="color:var(--yellow);font-weight:700">${pct}%</span></div><div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%"></div></div><div class="tip">${s.done} / ${s.total} topics done</div></div>`;
  }).join('');
}
function loadStudProgress(){const d=getUserData();if((d.studProgress||[]).length)renderStudProgress();}

// ===== COLLEGE EXPENSE =====
function calcColExp(){
  const t=+document.getElementById('colTuition').value;
  const h=+document.getElementById('colHostel').value;
  const f=+document.getElementById('colFood').value;
  const b=+document.getElementById('colBooks').value;
  const tr=+document.getElementById('colTrans').value;
  const o=+document.getElementById('colOther').value;
  const sems=+document.getElementById('colSems').value;
  const perSem=t+h+f+b+tr+o;
  const total=perSem*sems;
  const rb=document.getElementById('colResult');
  rb.className='result-box show';
  rb.innerHTML=`<div class="result-label">Total College Expense</div><div class="result-value">₹${total.toFixed(0)}</div><div class="tip">Per Semester: ₹${perSem.toFixed(0)} × ${sems} sems</div>`;
  addHistory('College Expense','Total ₹'+total.toFixed(0)+' over '+sems+' semesters');
}

// ===== HISTORY =====
function renderHistory(){
  const d=getUserData();const hist=d.history||[];
  if(!hist.length){document.getElementById('histList').innerHTML='<p style="color:var(--muted);text-align:center;margin-top:40px">No history yet. Start calculating!</p>';return;}
  document.getElementById('histList').innerHTML=hist.map(h=>`<div class="hist-entry"><div><div class="h-type">${h.type}</div><div class="h-content">${h.content}</div></div><div class="h-time">${h.time}</div></div>`).join('');
}
function clearHistory(){
  const d=getUserData();d.history=[];saveUserData(d);renderHistory();
}

